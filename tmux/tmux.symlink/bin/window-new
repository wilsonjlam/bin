#!/usr/bin/env bash
# window-new: Create a new Claude Code window in the current tmux session
# Usage: window-new [name] [working-directory]

NAME="${1:-$(date +%H%M%S)}"
WORKDIR="${2:-$(pwd)}"

# Create a new window running claude, with CLAUDE_WINDOW_NAME set
# so our hooks can identify it and write per-pane state files.
tmux new-window -n "claude:${NAME}" -c "$WORKDIR" \
    "CLAUDE_WINDOW_NAME='${NAME}' claude --dangerously-skip-permissions"

# Disable automatic-rename so our status updater controls the name
tmux set-option -w automatic-rename off
