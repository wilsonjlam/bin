#!/usr/bin/env bash
# pane-switcher: fzf-powered pane switcher for all tmux panes
# Panes with hook-provided state get status indicators.

# Cache hostname for pane_title comparison (default title is the hostname)
_hostname=$(hostname -s 2>/dev/null)

build_entries() {
    local current_pane
    current_pane=$(tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)

    local panes
    panes=$(tmux list-panes -a \
        -F '#{session_name}:#{window_index}.#{pane_index}	#{pane_id}	#{window_name}	#{pane_title}	#{pane_current_command}	#{pane_current_path}' 2>/dev/null)

    if [[ -z "$panes" ]]; then
        return 1
    fi

    # First pass: collect data and find max widths
    local -a rows=()
    local max_session=0 max_window=0 max_pane=0 max_cmd=0

    while IFS=$'\t' read -r target pane_id window_name pane_title command path; do
        local session_name="${target%%:*}"

        # Strip status prefixes from window name
        local clean_window
        clean_window=$(echo "$window_name" | sed 's/^[вЧПвЬУ?вЧЛв†Лв†Щв†єв†Єв†Љв†ів†¶в†І ]*//')
        clean_window="${clean_window#claude:}"
        [[ -z "$clean_window" ]] && clean_window="$command"

        # Pane name
        local pane_part="-"
        if [[ -n "$pane_title" && "$pane_title" != "$_hostname" && "$pane_title" != "$HOSTNAME" ]]; then
            pane_part="${pane_title:0:40}"
        fi

        local short_cmd="${command:0:30}"

        # Marker
        local marker="  "
        [[ "$target" == "$current_pane" ]] && marker="вЦЇ "

        # Icon
        local icon="  "
        local input_type
        input_type=$(tmux show-option -pqv -t "$pane_id" @pane_state 2>/dev/null)
        if [[ -n "$input_type" ]]; then
            case "$input_type" in
                question)       icon="рЯФі" ;;
                tool_approval)  icon="рЯФі" ;;
                finished)       icon="вЬЕ" ;;
                processing)     icon="рЯЯҐ" ;;
                *)              icon="вЪ™" ;;
            esac
        fi

        # Track max widths
        (( ${#session_name} > max_session )) && max_session=${#session_name}
        (( ${#clean_window} > max_window )) && max_window=${#clean_window}
        (( ${#pane_part} > max_pane )) && max_pane=${#pane_part}
        (( ${#short_cmd} > max_cmd )) && max_cmd=${#short_cmd}

        rows+=("${marker}|${icon}|${session_name}|${clean_window}|${pane_part}|${short_cmd}|${target}")
    done <<< "$panes"

    # Compute index width for padding
    local num_rows=${#rows[@]}
    local idx_width=${#num_rows}

    # Ensure min widths for header labels
    (( max_session < 7 )) && max_session=7
    (( max_window < 6 )) && max_window=6
    (( max_pane < 4 )) && max_pane=4
    (( max_cmd < 7 )) && max_cmd=7

    # Build header
    _header=$(printf "     %${idx_width}s  %-${max_session}s вФВ %-${max_window}s вФВ %-${max_pane}s вЙЂ %-${max_cmd}s" \
        "#" "SESSION" "WINDOW" "PANE" "COMMAND")

    # Second pass: format with aligned columns
    _entries=""
    local idx=1
    for row in "${rows[@]}"; do
        IFS='|' read -r marker icon session_name clean_window pane_part short_cmd target <<< "$row"
        local line
        line=$(printf "%s%s %${idx_width}d. %-${max_session}s вФВ %-${max_window}s вФВ %-${max_pane}s вЙЂ %-${max_cmd}s" \
            "$marker" "$icon" "$idx" "$session_name" "$clean_window" "$pane_part" "$short_cmd")
        _entries+="${line}	${target}"$'\n'
        ((idx++))
    done
}

# Main loop: re-show menu after kills
while true; do
    _entries=""
    _header=""
    build_entries || { echo "No panes found."; exit 0; }

    result=$(echo -n "$_entries" | fzf --height=40% --reverse --ansi \
        --delimiter='\t' --with-nth=1 \
        --expect=ctrl-x,ctrl-n \
        --prompt="Switch to pane > " \
        --header="$_header  вФВ  Enter=switch  C-x=kill  C-n=new session")

    # fzf --expect outputs: line 1 = key pressed, line 2 = selected entry
    key=$(echo "$result" | head -1)
    selected=$(echo "$result" | tail -1)

    # Esc or empty selection вАФ exit
    [[ -z "$selected" ]] && exit 0

    target=$(echo "$selected" | cut -f2)

    if [[ "$key" == "ctrl-n" ]]; then
        # Prompt for session name using fzf as input
        name=$(printf '' | fzf --print-query --prompt='New session name: ' --header='Enter=create  Esc=cancel' | head -1)
        if [[ -n "$name" ]]; then
            tmux new-session -d -s "$name"
            tmux switch-client -t "$name"
            exit 0
        fi
        # Empty name or Esc вАФ loop back to menu
    elif [[ "$key" == "ctrl-x" ]]; then
        # Count panes in this window and windows in this session
        session_part="${target%%:*}"
        window_part="${target%.*}"
        pane_count=$(tmux list-panes -t "$window_part" 2>/dev/null | wc -l | tr -d ' ')
        window_count=$(tmux list-windows -t "$session_part" 2>/dev/null | wc -l | tr -d ' ')

        if (( pane_count > 1 )); then
            tmux kill-pane -t "$target"
        elif (( window_count > 1 )); then
            tmux kill-window -t "$window_part"
        else
            tmux kill-session -t "$session_part"
        fi
        # Loop back to show updated menu
    else
        tmux switch-client -t "$target"
        exit 0
    fi
done
