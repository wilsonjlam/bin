#!/usr/bin/env bash
# tmux-pane-menu: fzf-powered pane switcher for ALL tmux panes
# Claude panes get status indicators; other panes show their command.

STATE_DIR="$HOME/.claude-sessions"

# List ALL panes across all sessions
# Include pane_index so we can target the exact pane
panes=$(tmux list-panes -a \
    -F '#{session_name}:#{window_index}.#{pane_index}	#{pane_id}	#{window_name}	#{pane_current_command}	#{pane_current_path}	#{pane_title}' 2>/dev/null)

if [[ -z "$panes" ]]; then
    echo "No panes found."
    exit 0
fi

# Get current pane so we can mark it
current_pane=$(tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)
# Cache hostname for pane_title comparison (default title is the hostname)
_hostname=$(hostname -s 2>/dev/null)

entries=""
while IFS=$'\t' read -r target pane_id window_name command path pane_title; do
    # Shorten home directory in path
    short_path="${path/#$HOME/\~}"
    # Truncate long paths to last 2 components
    if [[ $(echo "$short_path" | tr '/' '\n' | wc -l) -gt 3 ]]; then
        short_path="…/$(echo "$short_path" | rev | cut -d'/' -f1-2 | rev)"
    fi

    # Mark current pane
    marker="  "
    [[ "$target" == "$current_pane" ]] && marker="► "

    # Use pane_title if user has set one (ignore default hostname)
    display_name="$window_name"
    if [[ -n "$pane_title" && "$pane_title" != "$_hostname" && "$pane_title" != "$HOSTNAME" ]]; then
        display_name="${window_name}:${pane_title}"
    fi

    if [[ "$command" == "claude" ]]; then
        # Claude pane: show status from state file
        input_type=""
        state_file="$STATE_DIR/${pane_id}.state"
        [[ -f "$state_file" ]] && input_type=$(cat "$state_file" 2>/dev/null)

        case "$input_type" in
            question)       icon="🔴 INPUT" ;;
            tool_approval)  icon="🔴 APPROVE" ;;
            finished)       icon="✅ done" ;;
            processing)     icon="🟢 working" ;;
            *)              icon="⚪ idle" ;;
        esac
        entries+="${marker}${icon}  ${display_name}  ${short_path}  (${target})"$'\n'
    else
        # Non-Claude pane: show command
        entries+="${marker}   ${display_name}  [${command}]  ${short_path}  (${target})"$'\n'
    fi
done <<< "$panes"

selected=$(echo -n "$entries" | fzf --height=40% --reverse --ansi \
    --prompt="Switch to pane > " \
    --header="Enter=switch  Esc=cancel")

if [[ -n "$selected" ]]; then
    # Extract session:window.pane from the parenthesized target at end of line
    target=$(echo "$selected" | sed 's/.*(\([^)]*\)).*/\1/')
    # switch-client handles both window AND pane selection in one call
    tmux switch-client -t "$target"
fi
